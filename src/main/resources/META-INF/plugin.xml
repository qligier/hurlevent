<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>ch.qligier.jetbrains.plugin.hurlevent</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>Hurlevent</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://github.com/qligier/">Quentin Ligier</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Simple HTML elements (text formatting, paragraphs, and lists) can be added inside of <![CDATA[ ]]> tag.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
    <description><![CDATA[
    A plugin that adds support for the <a href="https://hurl.dev/">hurl</a> language.

    <a href="https://github.com/qligier/hurlevent">Source code</a> |
    <a href="https://github.com/qligier/hurlevent/issues">Issues</a> |
    <a href="https://www.linkedin.com/in/qligier/">LinkedIn</a>
  ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends optional="true" config-file="plugin_with_json.xml">com.intellij.modules.json</depends>
    <depends optional="true" config-file="plugin_with_graphql.xml">com.intellij.lang.jsgraphql</depends>
    <depends optional="true" config-file="plugin_with_jsonpath.xml">com.intellij.jsonpath</depends>
    <depends optional="true" config-file="plugin_with_xpath.xml">XPathView</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileIconProvider implementation="ch.qligier.jetbrains.plugin.hurlevent.language.HurlFileIconProvider"/>
        <colorSettingsPage
                implementation="ch.qligier.jetbrains.plugin.hurlevent.language.highlight.HurlColorSettingsPage"/>

        <!-- The Hurl language -->
        <fileType name="Hurl" language="hurl" extensions="hurl"
                  implementationClass="ch.qligier.jetbrains.plugin.hurlevent.language.HurlFileType"/>
        <lang.documentationProvider language="hurl"
                                    implementationClass="ch.qligier.jetbrains.plugin.hurlevent.language.documentation.HurlFilterDocumentationProvider"/>
        <lang.parserDefinition language="hurl"
                               implementationClass="ch.qligier.jetbrains.plugin.hurlevent.language.parser.HurlParserDefinition"/>
        <lang.syntaxHighlighterFactory language="hurl"
                                       implementationClass="ch.qligier.jetbrains.plugin.hurlevent.language.highlight.HurlSyntaxHighlighterFactory"/>
        <annotator language="hurl" implementationClass="ch.qligier.jetbrains.plugin.hurlevent.language.highlight.HurlSyntaxAnnotator"/>
        <lang.commenter language="hurl"
                        implementationClass="ch.qligier.jetbrains.plugin.hurlevent.language.editor.HurlCommenter"/>
        <lang.foldingBuilder language="hurl"
                             implementationClass="ch.qligier.jetbrains.plugin.hurlevent.language.editor.HurlFoldingBuilder"/>
        <lang.psiStructureViewFactory language="hurl"
                                      implementationClass="ch.qligier.jetbrains.plugin.hurlevent.language.structure.HurlStructureViewFactory"/>
        <breadcrumbsInfoProvider
                implementation="ch.qligier.jetbrains.plugin.hurlevent.language.editor.HurlBreadcrumbsProvider"/>

        <annotator language="hurl"
                   implementationClass="ch.qligier.jetbrains.plugin.hurlevent.language.inspection.DeprecatedFilterAnnotator"/>
        <annotator language="hurl"
                   implementationClass="ch.qligier.jetbrains.plugin.hurlevent.language.inspection.UnknownCharsetAnnotator"/>

        <multiHostInjector implementation="ch.qligier.jetbrains.plugin.hurlevent.language.injector.XmlBodyInjector"/>
        <multiHostInjector
                implementation="ch.qligier.jetbrains.plugin.hurlevent.language.injector.XmlFencedBodyInjector"/>
        <multiHostInjector implementation="ch.qligier.jetbrains.plugin.hurlevent.language.injector.RegexStringValueInjector"/>
        <multiHostInjector
                implementation="ch.qligier.jetbrains.plugin.hurlevent.language.injector.RegexQuotedStringValueInjector"/>
        <spellchecker.support language="hurl"
                              implementationClass="ch.qligier.jetbrains.plugin.hurlevent.language.editor.HurlSpellcheckingStrategy"/>
    </extensions>

    <applicationListeners>
    </applicationListeners>

    <actions>
        <action id="Hurl.NewFile"
                class="ch.qligier.jetbrains.plugin.hurlevent.language.action.CreateHurlFileAction"
                text="Hurl File"
                description="Creates a new Hurl file">
            <add-to-group group-id="NewGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
